{
  "name": "rcan-ts",
  "version": "2.0.0",
  "description": "Official TypeScript SDK for the RCAN v3.0 robot communication protocol",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "postbuild": "chmod +x bin/rcan-validate.mjs",
    "test": "node --experimental-vm-modules ./node_modules/.bin/jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "robotics",
    "rcan",
    "protocol",
    "ai-safety",
    "embodied-ai",
    "typescript"
  ],
  "author": "Craig Merry <cmmerry@ucdavis.edu>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/continuonai/rcan-ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest/presets/default-esm",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true,
          "tsconfig": {
            "module": "ESNext",
            "moduleResolution": "Bundler"
          }
        }
      ]
    },
    "globals": {},
    "injectGlobals": true,
    "transformIgnorePatterns": [],
    "setupFilesAfterEnv": [
      "<rootDir>/tests/jest.setup.ts"
    ]
  },
  "browser": "dist/browser.mjs",
  "cdn": "./dist/rcan.iife.js",
  "unpkg": "./dist/rcan.iife.js",
  "jsdelivr": "./dist/rcan.iife.js",
  "bin": {
    "rcan-validate": "./bin/rcan-validate.mjs"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "overrides": {
    "handlebars": "^4.7.9"
  },
  "dependencies": {
    "@noble/post-quantum": "^0.5.4"
  }
}
