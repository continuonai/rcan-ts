{
  "name": "rcan-ts",
  "version": "0.1.0",
  "description": "Official TypeScript SDK for the RCAN v1.2 robot communication protocol",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "browser": "./dist/browser.mjs",
      "import": "./dist/index.mjs",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "jest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "robotics",
    "rcan",
    "protocol",
    "ai-safety",
    "embodied-ai",
    "typescript"
  ],
  "author": "Craig Merry <cmmerry@ucdavis.edu>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/continuonai/rcan-ts"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "tsup": "^8.5.1",
    "typescript": "^5.3.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    }
  },
  "browser": "dist/browser.mjs",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false
}